---
import Base from '../layouts/Base.astro';
import DatelineBar from '../components/DatelineBar.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/Hero.astro';
import NetworkStrip from '../components/NetworkStrip.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Packages from '../components/Packages.astro';
import Cities from '../components/Cities.astro';
import Directory from '../components/Directory.astro';
import Testimonials from '../components/Testimonials.astro';
import Faq from '../components/Faq.astro';
import FooterCta from '../components/FooterCta.astro';
import SiteFooter from '../components/SiteFooter.astro';
import '../styles/tokens.css';
---
<Base>
  <div style="overflow-x: hidden;">
    <DatelineBar />
    <SiteHeader />
    <main>
      <Hero />
      <NetworkStrip />
      <HowItWorks />
      <Packages />
      <Cities />
      <Directory />
      <Testimonials />
      <Faq />
      <FooterCta />
    </main>
    <SiteFooter />
  </div>
</Base>
