---
---
<div class="alc">
  <div class="left">
    <p class="kicker">Buy à la carte</p>
    <h3>Need a custom volume? Order any number of articles.</h3>
    <div class="slider-row">
      <input type="range" id="alc-range" min="1" max="500" value="50" aria-label="Number of articles" />
      <div class="qty-label" id="alc-label">50 articles</div>
    </div>
    <div class="tiers">
      <div class="tier-row" id="tier-1-24">
        <span class="tier-range">1–24</span>
        <span class="tier-sep"></span>
        <span class="tier-rate">$12 / article</span>
      </div>
      <div class="tier-row" id="tier-25-49">
        <span class="tier-range">25–49</span>
        <span class="tier-sep"></span>
        <span class="tier-rate">$12 / article</span>
      </div>
      <div class="tier-row" id="tier-50-99">
        <span class="tier-range">50–99</span>
        <span class="tier-sep"></span>
        <span class="tier-rate">$11 / article</span>
      </div>
      <div class="tier-row" id="tier-100-249">
        <span class="tier-range">100–249</span>
        <span class="tier-sep"></span>
        <span class="tier-rate">$10 / article</span>
      </div>
      <div class="tier-row" id="tier-250">
        <span class="tier-range">250+</span>
        <span class="tier-sep"></span>
        <span class="tier-rate">$9 / article</span>
      </div>
    </div>
  </div>
  <div class="right">
    <div class="est-label">Estimated total</div>
    <div class="total" id="alc-total">$550</div>
    <div class="per-note" id="alc-per">$11 / article</div>
    <a href="#" class="cta" id="alc-cta">Order 50 articles</a>
  </div>
</div>

<script>
  const range   = document.getElementById('alc-range') as HTMLInputElement;
  const label   = document.getElementById('alc-label')!;
  const total   = document.getElementById('alc-total')!;
  const perNote = document.getElementById('alc-per')!;
  const cta     = document.getElementById('alc-cta')!;

  const fmt    = (n: number) => '$' + n.toLocaleString('en-US');
  const plural = (n: number) => n + (n === 1 ? ' article' : ' articles');

  const tiers = [
    { min: 1,   max: 24,  rate: 12, id: 'tier-1-24'   },
    { min: 25,  max: 49,  rate: 12, id: 'tier-25-49'  },
    { min: 50,  max: 99,  rate: 11, id: 'tier-50-99'  },
    { min: 100, max: 249, rate: 10, id: 'tier-100-249' },
    { min: 250, max: Infinity, rate: 9, id: 'tier-250' },
  ];

  function getRate(q: number) {
    return tiers.find(t => q >= t.min && q <= t.max)!;
  }

  function sync() {
    const q    = parseInt(range.value, 10);
    const tier = getRate(q);

    label.textContent   = plural(q);
    total.textContent   = fmt(q * tier.rate);
    perNote.textContent = `$${tier.rate} / article`;
    cta.textContent     = 'Order ' + plural(q);

    // Highlight active tier row
    tiers.forEach(t => {
      const el = document.getElementById(t.id)!;
      el.classList.toggle('active', t.id === tier.id);
    });
  }

  range.addEventListener('input', sync);
  sync();
</script>

<style>
  .alc {
    margin-top: 34px;
    background: var(--paper-card);
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    padding: 30px 34px;
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 44px;
    align-items: center;
  }
  .left .kicker { margin: 0 0 10px; }
  h3 {
    font-family: var(--f-serif);
    font-weight: 600;
    font-size: 24px;
    margin: 0 0 18px;
  }
  .slider-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 16px;
  }
  input[type=range] { flex: 1; }
  .qty-label {
    font-family: var(--f-mono);
    font-size: 14px;
    min-width: 96px;
    text-align: right;
  }

  /* Tier table */
  .tiers {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .tier-row {
    display: flex;
    align-items: center;
    padding: 7px 12px;
    font-family: var(--f-mono);
    font-size: 11.5px;
    color: var(--ink-mute);
    border-bottom: 1px solid var(--rule);
    transition: background 0.12s, color 0.12s;
  }
  .tier-row:last-child { border-bottom: none; }
  .tier-range { min-width: 52px; }
  .tier-sep {
    flex: 1;
    height: 1px;
    background: var(--rule);
    margin: 0 10px;
  }
  .tier-row.active {
    background: var(--ink);
    color: #F5F1E8;
  }
  .tier-row.active .tier-sep { background: rgba(255,255,255,0.2); }

  /* Right column */
  .right {
    border-left: 1px solid var(--rule);
    padding-left: 44px;
  }
  .est-label { font-size: 13px; color: var(--ink-mute); margin-bottom: 6px; }
  .total {
    font-family: var(--f-display);
    font-size: 52px;
    line-height: 1;
    margin-bottom: 4px;
  }
  .per-note {
    font-family: var(--f-mono);
    font-size: 12px;
    color: var(--ink-mute);
    margin-bottom: 20px;
  }
  .cta {
    background: var(--red);
    color: #fff;
    text-decoration: none;
    padding: 13px 26px;
    border-radius: var(--radius);
    font-size: 15px;
    font-weight: 700;
    transition: background 0.15s;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .cta:hover { background: var(--red-dark); }

  @media (max-width: 960px) {
    .alc {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .right {
      border-left: none;
      border-top: 1px solid var(--rule);
      padding-left: 0;
      padding-top: 28px;
    }
  }
</style>
