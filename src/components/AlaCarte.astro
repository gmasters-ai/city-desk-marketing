---
---
<div class="alc">
  <div class="left">
    <p class="kicker">Buy à la carte</p>
    <h3>Need a custom volume? Order any number of articles.</h3>
    <div class="slider-row">
      <input type="range" id="alc-range" min="1" max="500" value="50" aria-label="Number of articles" />
      <div class="qty-label" id="alc-label">50 articles</div>
    </div>
    <p class="note">Flat $12 / article &middot; bundles bring it as low as $9</p>
  </div>
  <div class="right">
    <div class="est-label">Estimated total</div>
    <div class="total" id="alc-total">$600</div>
    <a href="#" class="cta" id="alc-cta">Order 50 articles</a>
  </div>
</div>

<script>
  const range  = document.getElementById('alc-range') as HTMLInputElement;
  const label  = document.getElementById('alc-label')!;
  const total  = document.getElementById('alc-total')!;
  const cta    = document.getElementById('alc-cta')!;
  const fmt    = (n: number) => '$' + n.toLocaleString('en-US');
  const plural = (n: number) => n + (n === 1 ? ' article' : ' articles');

  function sync() {
    const q = parseInt(range.value, 10);
    label.textContent = plural(q);
    total.textContent = fmt(q * 12);
    cta.textContent   = 'Order ' + plural(q);
  }
  range.addEventListener('input', sync);
  sync();
</script>

<style>
  .alc {
    margin-top: 34px;
    background: var(--paper-card);
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    padding: 30px 34px;
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 44px;
    align-items: center;
  }
  .left .kicker { margin: 0 0 10px; }
  h3 {
    font-family: var(--f-serif);
    font-weight: 600;
    font-size: 24px;
    margin: 0 0 18px;
  }
  .slider-row {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  input[type=range] { flex: 1; }
  .qty-label {
    font-family: var(--f-mono);
    font-size: 14px;
    min-width: 96px;
    text-align: right;
  }
  .note {
    font-family: var(--f-mono);
    font-size: 11.5px;
    color: var(--ink-mute);
    margin: 12px 0 0;
  }
  .right {
    border-left: 1px solid var(--rule);
    padding-left: 44px;
  }
  .est-label { font-size: 13px; color: var(--ink-mute); margin-bottom: 6px; }
  .total {
    font-family: var(--f-display);
    font-size: 52px;
    line-height: 1;
    margin-bottom: 18px;
  }
  .cta {
    display: inline-block;
    background: var(--red);
    color: #fff;
    text-decoration: none;
    padding: 13px 26px;
    border-radius: var(--radius);
    font-size: 15px;
    font-weight: 700;
    transition: background 0.15s;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .cta:hover { background: var(--red-dark); }

  @media (max-width: 960px) {
    .alc {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .right {
      border-left: none;
      border-top: 1px solid var(--rule);
      padding-left: 0;
      padding-top: 28px;
    }
  }
</style>
